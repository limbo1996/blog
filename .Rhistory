def orderedSeqSearch(alist, item):
pos = 0
found = False
stop = False
while pos < len(alist) and not found and not stop:
if alist[pos] == item:
found = True
else:
if alist[pos] > item:
stop = True
else:
pos += 1
return found
testlist = [0, 1, 2, 8, 9, 10, 12, 23, 76]
orderedSeqSearch(testlist, 3)
orderedSeqSearch(testlist, 10)
